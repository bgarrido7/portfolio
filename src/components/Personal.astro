---
import { aboutMe } from "../data/aboutMe";
---

<section id="personal">
    <picture class="personal-logo">
        <img
            src={aboutMe.profile.picture}
            alt={aboutMe.profile.altText}
            width="200"
            height="200"
        />
    </picture>
    <div class="personal-content">
        <h1>{aboutMe.name}</h1>
        <p>
            {aboutMe.description}
        </p>
    </div>
</section>

<style>
    #personal {
        display: flex;
        gap:33px;
        .personal-logo {
            width: 100%;
            max-width: 200px;
            overflow: hidden;
            border-radius: 50%;
            margin-top: -30px;

            img {
                border-radius: 50%;
                border: 2px solid white;
            }
        }
        .personal-content {
            display: flex;
            flex-direction: column;
            @media (max-width: 768px) {
                align-items: center;
                text-align: center;
            }
        }

        .personal-content {
            h1 {
                font-size: 2.5em;
            }
            p {
                font-size: 1.2em;
                color: var(--text-color);
            }
            a[data-cta] {
                display: inline-block;
                padding: 10px 20px;
                background-color: var(--primary-color);
                color: #fff;
                text-decoration: none;
                border-radius: 5px;
                transition: background-color 0.3s ease;
                width: fit-content;

                &:hover {
                    background-color: transparent;
                    color: var(--primary-color);
                    border: 2px solid var(--primary-color);
                    text-decoration: underline;
                }
            }
        }
    }
</style>
